<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title><%= @title %> · cohere</title>
<meta name="description" content="<%= @description %>">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Marcellus&family=Source+Serif+4:ital,opsz,wght@0,8..60,300..700;1,8..60,300..700&family=Fragment+Mono:ital@0;1&display=swap" rel="stylesheet">
<link rel="stylesheet" href="assets/site.css">
<link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cg fill='none' stroke='%238a6b4d' stroke-width='1.6'%3E%3Cpath d='M16 3 C 24 2.5, 29.5 9, 29 16 C 28.5 24, 22 29.5, 15 29 C 8 28.5, 2.5 23, 3 15.5 C 3.5 8, 9 3.5, 16 3 Z'/%3E%3Cpath d='M16 8.5 C 21 8.2, 24.5 12, 24 16.5 C 23.5 21, 20 24, 15.5 23.5 C 11 23, 8 20, 8.5 15.5 C 9 11, 12 8.8, 16 8.5 Z'/%3E%3Ccircle cx='16' cy='16' r='2.2' fill='%2322303a' stroke='none'/%3E%3C/g%3E%3C/svg%3E">
</head>
<body class="page-<%= @kind %>">
<a class="skip" href="#main">Skip to content</a>
<header class="masthead">
  <a class="brand" href="index.html">Cohere</a>
  <p class="brand-sub">a coherence layer for Elixir / Phoenix</p>
  <nav aria-label="Pages">
    <%= for {slug, title} <- @nav do %><a href="<%= slug %>.html"<%= if slug == @slug do %> aria-current="page"<% end %>><%= title %></a><% end %>
  </nav>
</header>
<div class="graduation" aria-hidden="true"></div>
<main id="main" class="sheet">
<%= if @slug != "index" do %>
<h1 class="page-title"><%= @title %></h1>
<% end %>
<%= @content %>
</main>
<footer>
  <p>cohere <%= @version %> · derived where possible, authored where necessary</p>
  <p><a href="<%= @slug %>.md">this page as markdown</a> · <a href="llms.txt">llms.txt</a> · <a href="https://github.com/mhyrr/cohere">github</a> · MIT</p>
</footer>
</body>
</html>
